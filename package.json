{
  "name": "prism-applause-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for public-kudos Clarity contract interactions on Stacks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "dev": "tsup --watch",
    "example:connect": "tsx examples/connect-flow.ts",
    "example:read": "tsx examples/read-only-leaderboard.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run lint && npm run typecheck && npm run test && npm run build",
    "pack:check": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --access public"
  },
  "keywords": [
    "stacks",
    "clarity",
    "kudos",
    "sdk",
    "web3"
  ],
  "author": "xqcxx <praisechinonso21@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/realvic22/prism-applause-sdk.git"
  },
  "homepage": "https://github.com/realvic22/prism-applause-sdk#readme",
  "bugs": {
    "url": "https://github.com/realvic22/prism-applause-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10",
  "dependencies": {
    "@stacks/transactions": "^7.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
